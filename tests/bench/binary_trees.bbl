(= make-tree (fn (depth)
    (if (<= depth 0)
        (table "left" null "right" null "val" 1)
        (table "left" (make-tree (- depth 1))
               "right" (make-tree (- depth 1))
               "val" depth))))
(= check-tree (fn (t)
    (if (== (t:get "left") null)
        (t:get "val")
        (+ (t:get "val") (+ (check-tree (t:get "left")) (check-tree (t:get "right")))))))
(= run (fn ()
    (= min-depth 4)
    (= max-depth 14)
    (= stretch (make-tree (+ max-depth 1)))
    (= sum 0)
    (= d min-depth)
    (loop (<= d max-depth)
        (= iterations (+ 1 0))
        (= j 0)
        (loop (< j (- max-depth d))
            (= iterations (* iterations 2))
            (= j (+ j 1)))
        (= i 0)
        (= check 0)
        (loop (< i iterations)
            (= t (make-tree d))
            (= check (+ check (check-tree t)))
            (= i (+ i 1)))
        (= sum (+ sum check))
        (= d (+ d 2)))
    (print sum)))
(run)
