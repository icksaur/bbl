(= run (fn ()
    (= make-adder (fn (x y) (fn () (+ x y))))
    (= makers (table))
    (= i 0)
    (loop (< i 10000)
        (makers:push (make-adder i (* i 2)))
        (= i (+ i 1)))
    (= sum 0)
    (= i 0)
    (loop (< i 10000)
        (= f (makers:get i))
        (= sum (+ sum (f)))
        (= i (+ i 1)))
    (print sum)))
(run)
