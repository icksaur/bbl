(= run (fn ()
    (= v (vector int 1 2 3 4 5))
    (= t (table "a" 1 "b" 2 "c" 3))
    (= s "hello world")
    (= sum 0)
    (= i 0)
    (loop (< i 100000)
        (= sum (+ sum (v:at (% i 5))))
        (= sum (+ sum (t:get (if (== (% i 3) 0) "a" (if (== (% i 3) 1) "b" "c")))))
        (= sum (+ sum (s:length)))
        (= i (+ i 1)))
    (print sum)))
(run)
