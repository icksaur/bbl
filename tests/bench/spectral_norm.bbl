(= run (fn ()
    (= spectral-norm (fn (n)
        (= A (fn (i j) (/ 1.0 (+ (/ (* (+ i j) (+ i j 1)) 2.0) i 1))))
        (= u (table))
        (= v (table))
        (= i 0)
        (loop (< i n)
            (u:set i 1.0)
            (v:set i 0.0)
            (= i (+ i 1)))
        (= k 0)
        (loop (< k 10)
            (= i 0)
            (loop (< i n)
                (= s 0.0)
                (= j 0)
                (loop (< j n)
                    (= s (+ s (* (A i j) (u:get j))))
                    (= j (+ j 1)))
                (v:set i s)
                (= i (+ i 1)))
            (= i 0)
            (loop (< i n)
                (= s 0.0)
                (= j 0)
                (loop (< j n)
                    (= s (+ s (* (A i j) (v:get j))))
                    (= j (+ j 1)))
                (u:set i s)
                (= i (+ i 1)))
            (= k (+ k 1)))
        (= vbv 0.0)
        (= vv 0.0)
        (= i 0)
        (loop (< i n)
            (= vbv (+ vbv (* (u:get i) (v:get i))))
            (= vv (+ vv (* (v:get i) (v:get i))))
            (= i (+ i 1)))
        (print vbv)))
    (spectral-norm 500)))
(run)
