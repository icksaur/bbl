(= run (fn ()
    (= data "12,34,56,78,90,11,22,33,44,55,66,77,88,99,10,20,30,40,50,60")
    (= len (data:length))
    (= sum 0)
    (= i 0)
    (loop (< i 50000)
        (= pos 0)
        (loop (< pos len)
            (= comma (data:find "," pos))
            (= end (if (== comma -1) len comma))
            (= sum (+ sum (int (data:slice pos (- end pos)))))
            (= pos (+ end 1)))
        (= i (+ i 1)))
    (print sum)))
(run)
