// table_heavy.bbl — table insert and lookup at scale
// Measures: BblTable linear scan, GC from table allocations
(= t (table))
(= i 0)
(loop (< i 1000)
    (t:set i (* i i))
    (= i (+ i 1))
)
// Read back all entries
(= i 0)
(= sum 0)
(loop (< i 1000)
    (= sum (+ sum (t:get i)))
    (= i (+ i 1))
)
(print sum)
