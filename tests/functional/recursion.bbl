// Recursive factorial
(= fact (fn (n)
    (= result 1)
    (if (<= n 1)
        (= result 1)
        (= result (* n (fact (- n 1))))
    )
    result
))
(print (fact 0) "\n")
(print (fact 1) "\n")
(print (fact 5) "\n")
(print (fact 10) "\n")

// Recursive fibonacci
(= fib (fn (n)
    (= result 0)
    (if (<= n 1)
        (= result n)
        (= result (+ (fib (- n 1)) (fib (- n 2))))
    )
    result
))
(print (fib 0) "\n")
(print (fib 1) "\n")
(print (fib 10) "\n")

// Recursive countdown — returns base case
(= countdown (fn (n)
    (= result n)
    (if (> n 0)
        (= result (countdown (- n 1)))
    )
    result
))
(print (countdown 5) "\n")

// Recursive sum of list elements via table
(= sum-table (fn (t i)
    (= result 0)
    (if (< i (t:length))
        (= result (+ (t:at i) (sum-table t (+ i 1))))
    )
    result
))
(= nums (table 0 1 1 2 2 3 3 4 4 5))
(print (sum-table nums 0) "\n")
