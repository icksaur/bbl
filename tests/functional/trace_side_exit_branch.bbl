// Side exit: branch direction changes mid-loop.
// A trace records the taken branch. When the condition flips,
// the guard fails and must side-exit with correct register state.
(= a 0)
(= b 0)
(= i 0)
(loop (< i 100)
  (if (< i 60)
    (= a (+ a i))
    (= b (+ b i)))
  (= i (+ i 1)))
(print a)
(print " ")
(print b)
